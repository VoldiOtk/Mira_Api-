GEMINI_API_KEY=AIzaSyA78yn3uJ6PZWC9Ugxw4lAtNTHH95OytBQ
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_FALLBACK_MODELS=gemini-3.1-flash-lite,gemini-2.5-flash-lite,gemini-2.0-flash-lite
AI_CONVERSATION_STYLE=casual
# local | cloud | auto  — cloud = API Google (GEMINI_API_KEY)
AI_PROVIDER=cloud
OLLAMA_MODEL=gemma4:e2b
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TIMEOUT_SECONDS=120

# ── LLM Translation Pipeline (Mira v2) ──────────────────────────────────────
# Provider for sequence-to-natural-language translation
# Options: gemini | local
#   gemini       — uses GEMINI_API_KEY with Gemma/Gemini models
#   local        — rule-based fallback (no external API required)
LLM_PROVIDER=gemini

# Set to false to disable LLM translation entirely (always use local fallback)
LLM_TRANSLATION_ENABLED=true

# Timeout (seconds) for LLM calls; falls back to local if exceeded
LLM_TIMEOUT_SECONDS=10

# ── SignSequenceBuilder tunables ─────────────────────────────────────────────
# Minimum confidence to count a frame toward sign confirmation
SEQUENCE_CONFIDENCE_THRESHOLD=0.65
# Number of stable frames required to confirm a sign
SEQUENCE_STABLE_FRAMES=3
# Sliding window size for smoothing predictions
SEQUENCE_SMOOTH_WINDOW=5
# Milliseconds before the same sign can be confirmed again (duplicate guard)
SEQUENCE_DUPLICATE_COOLDOWN_MS=1500
# Milliseconds of silence before auto-finalize is suggested
SEQUENCE_TIMEOUT_MS=5000
# Maximum number of signs in a sequence before oldest are dropped
SEQUENCE_MAX_LENGTH=20

# Precision tuning
PREDICTION_THRESHOLD=0.78
STABLE_WORD_THRESHOLD=0.90
TOP2_MARGIN_THRESHOLD=0.18
PREDICTION_HISTORY_SIZE=6
MIN_STABLE_COUNT=4
MIN_WORD_COOLDOWN_SECONDS=1.4
BUFFER_SILENCE_SECONDS=3.5
NON_SIGN_LABELS=space,del,nothing,blank

# Voix immédiate par mot (ASL label anglais → TTS dans langue UI)
INSTANT_SPEAK_LABELS=hello,thank you,thanks,yes,no,hi
WORD_SPEECH_COOLDOWN_SECONDS=2.5
INSTANT_SPEAK_CONFIDENCE=0.55
SPELL_LETTER_GAP_SECONDS=1.8

# Voix TTS par langue
TTS_VOICE_FR=fr-FR-DeniseNeural
TTS_VOICE_EN=en-US-JennyNeural

# WLASL — palier vocabulaire (voir docs/PLAN_ASL_FR.md)
# 2000 mots (base complete) :
WLASL_NSLT=nslt_2000.json
WLASL_USE_ALL_CLASSES=1
WLASL_MAX_VIDEOS_PER_CLASS=0

# Entrainement LSTM (apres process_wlasl.py)
# Mettre à true pour simuler l'entraînement sans données réelles (MVP)
MOCK_TRAINING=true
TRAIN_EPOCHS=80
TRAIN_BATCH_SIZE=16
TRAIN_LR=0.0005
TRAIN_VAL_SPLIT=0.1
# Administration API (/admin) + clés partenaires (header X-API-Key)
MIRA_ADMIN_PASSWORD=your_strong_admin_password
# Adresse e-mail du compte admin (reçoit les liens de réinitialisation)
ADMIN_EMAIL=admin@example.com
# URL publique du dashboard admin (utilisée pour construire le lien de reset)
FRONTEND_ADMIN_URL=http://127.0.0.1:8000/admin
# Environnement : development | production
APP_ENV=development
# false = démo / ngrok ouvert | true = production (hébergeur)
API_KEYS_REQUIRED=false

# ── Serveur backend ──────────────────────────────────────────────────────────
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# ── URLs frontends (pour emails, redirections, liens internes) ───────────────
ADMIN_FRONTEND_URL=http://127.0.0.1:8000/admin
CLIENT_FRONTEND_URL=http://127.0.0.1:8001
# Separate app ports (client: 8001, admin: 8002, backend: 8000)
CLIENT_APP_URL=http://127.0.0.1:8001
ADMIN_APP_URL=http://127.0.0.1:8002
# Production :
# ADMIN_FRONTEND_URL=https://admin.mira.com
# CLIENT_FRONTEND_URL=https://client.mira.com

# ── CORS — origines autorisées (séparées par des virgules) ───────────────────
# Dev : backend sert tout sur 8000, donc 8000 suffit. Ajoutez 5173 si Vite dev server.
ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://127.0.0.1:8001,http://localhost:8001,http://127.0.0.1:8002,http://localhost:8002,http://localhost:5173
# Production :
# ALLOWED_ORIGINS=https://admin.mira.com,https://client.mira.com

# ── E-mail (mot de passe oublié) ────────────────────────────────────────────
# URL publique de base pour construire les liens des e-mails (page de reset
# servie sous /static/espace-client/...). En dev : http://127.0.0.1:8000
APP_BASE_URL=http://127.0.0.1:8000
# Internal API URLs (used by client and admin apps to reach the backend)
MIRA_INTERNAL_API_URL=http://127.0.0.1:8000/api/v1
MIRA_PUBLIC_API_URL=http://127.0.0.1:8000/v1
# SMTP : si SMTP_HOST est vide, l'app NE plante PAS — l'e-mail n'est pas envoyé
# et l'endpoint /forgot-password renvoie un champ dev_reset_link pour tester.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@gvtechdrc.com
# true = STARTTLS (port 587) ; le port 465 bascule automatiquement en SSL implicite
SMTP_TLS=true

# PlanetHoster : passenger_wsgi.py (N0C) ou deploy/start_mira.sh (SSH)
