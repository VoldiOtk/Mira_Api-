# Database
DATABASE_URL=postgresql://mira:mira@localhost:5432/miraasl

# Redis (required for rate limiting in production; optional in dev — falls back to in-memory)
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
API_KEY_SECRET=change-me-use-openssl-rand-hex-32
MIRA_ADMIN_PASSWORD=change-me-admin-password

# S3 / MinIO
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET_DATASETS=asl-datasets
S3_BUCKET_MODELS=asl-models

# AI Providers
GEMINI_API_KEY=
AI_PROVIDER=auto
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b

# TTS
TTS_VOICE_FR=fr-FR-DeniseNeural
TTS_VOICE_EN=en-US-JennyNeural

# ML Config
PREDICTION_THRESHOLD=0.78
STABLE_WORD_THRESHOLD=0.90
API_KEYS_REQUIRED=true

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:8000

# Email alerts (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@mira-api.com
SMTP_PASSWORD=...
SMTP_FROM=noreply@mira-api.com
SMTP_TLS=true

# App
APP_BASE_URL=http://localhost:8000
APP_URL=https://mira-ai.com
